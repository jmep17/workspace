#!/usr/bin/env python3
"""Local web UI for managing Claude Code skills in this repo.

Usage:  bin/skills-ui [--port 7333]

Lists every skill under skills/ (and archive/), with actions: archive,
restore, delete, move between groups, upload a folder from disk, and
scaffolding a new skill. A "group" is any nested directory under skills/
without a SKILL.md of its own; Claude Code only discovers direct children
of the skills dir, so each group member gets an auto-managed top-level
<group>-<name> symlink. Stdlib only.
"""

import argparse
import base64
import json
import re
import shutil
import sys
import webbrowser
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
SKILLS = REPO / "skills"
ARCHIVE = REPO / "archive"
CLAUDE_SKILLS = Path.home() / ".claude" / "skills"

NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")


def parse_frontmatter(text):
    meta = {}
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return meta
    key = None
    buf = []
    for line in lines[1:]:
        if line.strip() == "---":
            break
        m = re.match(r"^([A-Za-z0-9_-]+):\s*(.*)$", line)
        if m:
            if key and buf:
                meta[key] = " ".join(buf).strip()
            val = m.group(2).strip()
            if val in (">", "|", ">-", "|-"):
                key, buf = m.group(1), []
            else:
                meta[m.group(1)] = val
                key, buf = None, []
        elif key and line.startswith((" ", "\t")):
            buf.append(line.strip())
    if key and buf:
        meta[key] = " ".join(buf).strip()
    return meta


def is_group(entry):
    """A group is a real (non-symlink) dir without its own SKILL.md."""
    return (entry.is_dir() and not entry.is_symlink()
            and not entry.name.startswith(".")
            and not (entry / "SKILL.md").is_file())


def group_names():
    """Known group names across skills/ and archive/."""
    names = set()
    for root in (SKILLS, ARCHIVE):
        if root.is_dir():
            names.update(e.name for e in root.iterdir() if is_group(e))
    return sorted(names)


def split_managed(name):
    """'<g>-<x>' -> (g, x) if g is a known group (longest match), else None."""
    for g in sorted(group_names(), key=len, reverse=True):
        if name.startswith(g + "-") and len(name) > len(g) + 1:
            return g, name[len(g) + 1:]
    return None


def reconcile_links():
    """Keep top-level <group>-<name> symlinks in sync with group contents.

    Claude Code only discovers direct children of the skills dir, so each
    content dir skills/<g>/<x> needs a skills/<g>-<x> symlink. Creates
    missing links and prunes broken links that point inside skills/.
    """
    for entry in sorted(SKILLS.iterdir()) if SKILLS.is_dir() else []:
        if not is_group(entry):
            continue
        for d in sorted(entry.iterdir()):
            if d.is_dir() and not d.name.startswith("."):
                link = SKILLS / f"{entry.name}-{d.name}"
                if not (link.exists() or link.is_symlink()):
                    link.symlink_to(Path(entry.name) / d.name)
    for entry in SKILLS.iterdir():
        if not entry.is_symlink():
            continue
        raw = entry.readlink()
        target = raw if raw.is_absolute() else SKILLS / raw
        try:
            inside = target.resolve().is_relative_to(SKILLS.resolve())
        except OSError:
            inside = False
        if inside and not target.exists():
            entry.unlink()


def item(entry, scope, name=None, group=None):
    skill_md = entry / "SKILL.md"
    meta = parse_frontmatter(skill_md.read_text(errors="replace")) if skill_md.is_file() else {}
    n = name or entry.name
    return {
        "name": n, "scope": scope, "symlink": entry.is_symlink(),
        "group": group, "managed": group is not None,
        "local": n.startswith("work-") or group == "work",
        "broken": False, "has_skill_md": skill_md.is_file(),
        "description": meta.get("description", ""),
        "files": sum(1 for p in entry.rglob("*") if p.is_file()),
        "path": str(entry),
        "movable": scope == "active" and (group is not None or not entry.is_symlink()),
    }


def scan(root, scope):
    items = []
    if not root.is_dir():
        return items
    root_res = root.resolve()
    for entry in sorted(root.iterdir()):
        if entry.name.startswith("."):
            continue
        if is_group(entry):
            # active group members surface via their top-level symlinks;
            # archived ones have no links, so list them directly
            if root == ARCHIVE:
                for d in sorted(entry.iterdir()):
                    if d.is_dir() and not d.name.startswith("."):
                        items.append(item(d, scope, name=f"{entry.name}-{d.name}",
                                          group=entry.name))
            continue
        if not entry.is_dir():
            if entry.is_symlink():
                items.append({
                    "name": entry.name, "scope": scope, "broken": True,
                    "symlink": True, "group": None, "managed": False,
                    "local": entry.name.startswith("work-"), "movable": False,
                    "description": "(broken symlink: " + str(entry.readlink()) + ")",
                    "files": 0,
                })
            continue
        group = None
        if entry.is_symlink():
            try:
                rp = entry.resolve()
                if rp.parent != root_res and rp.parent.parent == root_res:
                    group = rp.parent.name
            except OSError:
                pass
        items.append(item(entry, scope, group=group))
    return items


def link_status():
    """How ~/.claude/skills relates to this repo's skills/ directory."""
    home = str(Path.home())
    shown = str(CLAUDE_SKILLS).replace(home, "~", 1)
    info = {"path": shown, "repo_skills": str(SKILLS)}
    if CLAUDE_SKILLS.is_symlink():
        if CLAUDE_SKILLS.resolve() == SKILLS.resolve():
            info["status"] = "linked"
        else:
            info["status"] = "wrong-target"
            info["target"] = str(CLAUDE_SKILLS.readlink())
    elif CLAUDE_SKILLS.is_dir():
        info["status"] = "real-dir"
    else:
        info["status"] = "missing"
    return info


def set_up_link():
    """Point ~/.claude/skills at this repo's skills/. Returns backup path or None."""
    CLAUDE_SKILLS.parent.mkdir(parents=True, exist_ok=True)
    backup = None
    if CLAUDE_SKILLS.is_symlink():
        CLAUDE_SKILLS.unlink()
    elif CLAUDE_SKILLS.exists():
        n = 0
        while True:
            backup = CLAUDE_SKILLS.with_name("skills.bak" + (str(n) if n else ""))
            if not (backup.exists() or backup.is_symlink()):
                break
            n += 1
        CLAUDE_SKILLS.rename(backup)
    CLAUDE_SKILLS.symlink_to(SKILLS)
    return str(backup) if backup else None


def resolve(scope, name):
    """Return the entry path for a validated (scope, name), or raise."""
    if scope not in ("active", "archived"):
        raise ValueError("bad scope")
    if not NAME_RE.match(name or ""):
        raise ValueError("bad skill name")
    root = SKILLS if scope == "active" else ARCHIVE
    path = root / name
    if path.parent != root:
        raise ValueError("bad path")
    return path


def creation_path(name):
    """Where new content for `name` lives: inside its group if one matches."""
    sm = split_managed(name)
    return SKILLS / sm[0] / sm[1] if sm else SKILLS / name


def move_entry(src, dst_root):
    if not (src.is_dir() or src.is_symlink()):
        raise ValueError(f"{src.name}: not found")
    dst_root.mkdir(exist_ok=True)
    dst = dst_root / src.name
    if dst.exists() or dst.is_symlink():
        raise ValueError(f"{dst.name}: already exists in {dst_root.name}/")
    src.rename(dst)


SKILL_TEMPLATE = """---
name: {name}
description: TODO — one sentence on what this does, then "Use when ..." triggers.
---

# {name}

TODO: instructions.
"""

