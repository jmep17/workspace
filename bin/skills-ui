<script>
let DATA = { active: [], archived: [], groups: [] };

async function api(path, body) {
  const res = await fetch(path, body
    ? { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body) }
    : {});
  const json = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(json.error || res.statusText);
  return json;
}

function toast(msg, err) {
  const el = document.getElementById("toast");
  el.textContent = msg;
  el.className = "show" + (err ? " err" : "");
  clearTimeout(el._t);
  el._t = setTimeout(() => (el.className = ""), err ? 5000 : 2500);
}

function renderLink() {
  const el = document.getElementById("link");
  const l = DATA.link;
  if (!l) { el.hidden = true; return; }
  el.hidden = false;
  const btn = '<button onclick="doLink()">link now</button>';
  if (l.status === "linked") {
    el.className = "banner ok";
    el.innerHTML = `<span class="msg">✓ ${l.path} → this repo — skills load in Claude Code on this machine</span>`;
  } else if (l.status === "missing") {
    el.className = "banner warn";
    el.innerHTML = `<span class="msg">${l.path} is not set up — Claude Code won't see these skills</span>${btn}`;
  } else if (l.status === "wrong-target") {
    el.className = "banner warn";
    el.innerHTML = `<span class="msg">${l.path} points elsewhere (${esc(l.target)})</span>${btn}`;
  } else {
    el.className = "banner warn";
    el.innerHTML = `<span class="msg">${l.path} is a real directory — link it here (existing dir is backed up first)</span>${btn}`;
  }
}

async function doLink() {
  try {
    const r = await api("/api/link", {});
    toast(r.backup ? "linked — previous directory saved at " + r.backup : "linked");
    await refresh();
  } catch (e) { toast(e.message, true); }
}

function render() {
  renderLink();
  const q = document.getElementById("q").value.toLowerCase();
  for (const scope of ["active", "archived"]) {
    const items = DATA[scope].filter(
      (s) => !q || s.name.toLowerCase().includes(q) || (s.description || "").toLowerCase().includes(q)
    );
    document.getElementById("n-" + scope).textContent = "· " + DATA[scope].length;
    const box = document.getElementById(scope);
    box.innerHTML = "";
    if (!items.length) {
      box.innerHTML = '<div class="empty">' + (q ? "no matches" : "nothing here") + "</div>";
      continue;
    }
    for (const s of items) {
      const row = document.createElement("div");
      row.className = "row " + scope;
      const badges =
        (s.group ? `<span class="badge group">${esc(s.group)}/</span>` : "") +
        (s.local ? '<span class="badge local">gitignored</span>' : "") +
        (s.symlink && !s.managed ? '<span class="badge link">symlink</span>' : "") +
        (s.broken ? '<span class="badge warn">broken</span>' : "") +
        (s.has_skill_md === false && !s.broken ? '<span class="badge warn">no SKILL.md</span>' : "");
      const move = s.movable ? `<button onclick="moveToGroup('${s.name}')">move</button>` : "";
      const act =
        scope === "active"
          ? `<button onclick="doMove('archive','${s.name}')">archive</button>`
          : `<button onclick="doMove('restore','${s.name}')">restore</button>`;
      row.innerHTML =
        `<span class="name" title="${s.path || ""}">${s.name}</span>` + badges +
        `<span class="desc">${esc(s.description || "")}</span>` +
        `<span class="actions">${move}${act}<button class="danger" onclick="doDelete('${scope}','${s.name}',${s.managed})">delete</button></span>`;
      box.appendChild(row);
    }
  }
}

const esc = (t) => t.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

async function refresh() {
  DATA = await api("/api/skills");
  render();
}

async function doMove(action, name) {
  try {
    await api("/api/" + action, { name });
    toast(name + (action === "archive" ? " → archive/" : " → skills/"));
    await refresh();
  } catch (e) { toast(e.message, true); }
}

async function moveToGroup(name) {
  const gs = DATA.groups || [];
  const g = prompt(
    "Move to group — blank for top level" + (gs.length ? " (existing: " + gs.join(", ") + ")" : "") + ":", "");
  if (g === null) return;
  try {
    const r = await api("/api/move", { name, group: g.trim() });
    toast(name + " → " + r.name);
    await refresh();
  } catch (e) { toast(e.message, true); }
}

async function newGroup() {
  const name = prompt("New group (nested folder) name — 'work' stays out of git:");
  if (!name) return;
  try {
    await api("/api/group", { name: name.trim() });
    toast("group " + name + "/ created — use move to file skills into it");
    await refresh();
  } catch (e) { toast(e.message, true); }
}

async function doDelete(scope, name, managed) {
  const msg = managed
    ? "Permanently delete " + name + " and its files inside its group folder?"
    : "Permanently delete " + name + "? (a symlink's target is untouched)";
  if (!confirm(msg)) return;
  try {
    await api("/api/delete", { scope, name });
    toast(name + " deleted");
    await refresh();
  } catch (e) { toast(e.message, true); }
}

async function newSkill() {
  const name = prompt("Skill name (kebab-case; '<group>-' prefix files it in that group, work- stays out of git):");
  if (!name) return;
  try {
    const r = await api("/api/new", { name: name.trim() });
    toast("created " + r.path + " — edit its SKILL.md");
    await refresh();
  } catch (e) { toast(e.message, true); }
}

async function uploadSkill(ev) {
  const files = [...ev.target.files].filter(
    (f) => !/(^|\\/)(\\.git|node_modules)(\\/|$)|(^|\\/)\\.DS_Store$/.test(f.webkitRelativePath)
  );
  ev.target.value = "";
  if (!files.length) return;
  const root = files[0].webkitRelativePath.split("/")[0];
  const name = prompt(
    "Import as (a folder of skills becomes a group; '<group>-' prefix files a single skill into that group):", root);
  if (!name) return;
  const payload = [];
  for (const f of files) {
    const rel = f.webkitRelativePath.split("/").slice(1).join("/");
    if (!rel) continue;
    const buf = new Uint8Array(await f.arrayBuffer());
    let bin = "";
    for (const b of buf) bin += String.fromCharCode(b);
    payload.push({ path: rel, content_b64: btoa(bin) });
  }
  try {
    const r = await api("/api/upload", { name: name.trim(), files: payload });
    toast("imported " + r.path + " (" + r.files + " files)");
    await refresh();
  } catch (e) { toast(e.message, true); }
}

document.getElementById("up").addEventListener("change", uploadSkill);
document.getElementById("q").addEventListener("input", render);
refresh();
</script>
"""


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

    def send(self, code, body, ctype="application/json"):
        data = body.encode() if isinstance(body, str) else json.dumps(body).encode()
        self.send_response(code)
        self.send_header("content-type", ctype)
        self.send_header("content-length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def body(self):
        n = int(self.headers.get("content-length") or 0)
        return json.loads(self.rfile.read(n) or b"{}")

    def do_GET(self):
        if self.path == "/":
            self.send(200, PAGE, "text/html; charset=utf-8")
        elif self.path == "/api/skills":
            reconcile_links()
            self.send(200, {"active": scan(SKILLS, "active"),
                            "archived": scan(ARCHIVE, "archived"),
                            "groups": sorted(e.name for e in SKILLS.iterdir() if is_group(e)),
                            "link": link_status()})
        else:
            self.send(404, {"error": "not found"})

    def do_POST(self):
        try:
            req = self.body()
            name = req.get("name", "")
            if self.path == "/api/archive":
                src = resolve("active", name)
                sm = split_managed(name)
                if sm and src.is_symlink() and (SKILLS / sm[0] / sm[1]).is_dir():
                    g, x = sm
                    adir = ARCHIVE / g
                    if (adir / x).exists():
                        raise ValueError(f"{name}: already exists in archive/{g}/")
                    adir.mkdir(parents=True, exist_ok=True)
                    (SKILLS / g / x).rename(adir / x)
                    src.unlink()
                else:
                    move_entry(src, ARCHIVE)
            elif self.path == "/api/restore":
                sm = split_managed(name)
                if sm and (ARCHIVE / sm[0] / sm[1]).is_dir():
                    g, x = sm
                    gdir = SKILLS / g
                    if (gdir / x).exists():
                        raise ValueError(f"{name}: already exists in skills/{g}/")
                    gdir.mkdir(exist_ok=True)
                    (ARCHIVE / g / x).rename(gdir / x)
                    reconcile_links()
                else:
                    move_entry(resolve("archived", name), SKILLS)
            elif self.path == "/api/delete":
                scope = req.get("scope", "")
                path = resolve(scope, name)
                sm = split_managed(name)
                root = SKILLS if scope == "active" else ARCHIVE
                content = root / sm[0] / sm[1] if sm else None
                if scope == "active" and content and path.is_symlink() and content.is_dir():
                    path.unlink()
                    shutil.rmtree(content)
                elif (scope == "archived" and content and content.is_dir()
                        and not (path.exists() or path.is_symlink())):
                    shutil.rmtree(content)
                elif path.is_symlink():
                    path.unlink()
                elif path.is_dir():
                    shutil.rmtree(path)
                else:
                    raise ValueError(f"{name}: not found")
            elif self.path == "/api/move":
                dest_g = (req.get("group") or "").strip()
                if dest_g and not NAME_RE.match(dest_g):
                    raise ValueError("bad group name")
                entry = resolve("active", name)
                sm = split_managed(name)
                if sm and entry.is_symlink() and (SKILLS / sm[0] / sm[1]).is_dir():
                    src, link, base = SKILLS / sm[0] / sm[1], entry, sm[1]
                elif entry.is_dir() and not entry.is_symlink():
                    src, link, base = entry, None, name
                else:
                    raise ValueError(f"{name}: only real skill dirs and group members can move")
                if dest_g:
                    gdir = SKILLS / dest_g
                    if not is_group(gdir):
                        raise ValueError(f"{dest_g}: no such group (create it with + group)")
                    dst, new_name = gdir / base, f"{dest_g}-{base}"
                    taken = SKILLS / new_name
                    if taken.exists() or taken.is_symlink():
                        raise ValueError(f"{new_name}: name already taken")
                else:
                    dst, new_name = SKILLS / base, base
                if dst == src:
                    raise ValueError(f"{name}: already there")
                if dst.exists() or dst.is_symlink():
                    raise ValueError(f"{dst.name}: already exists")
                src.rename(dst)
                if link:
                    link.unlink()
                reconcile_links()
                self.send(200, {"ok": True, "name": new_name})
                return
            elif self.path == "/api/group":
                if not NAME_RE.match(name):
                    raise ValueError("bad group name")
                gdir = SKILLS / name
                if gdir.exists() or gdir.is_symlink():
                    raise ValueError(f"{name}: already exists")
                gdir.mkdir()
            elif self.path == "/api/link":
                backup = set_up_link()
                self.send(200, {"ok": True, "backup": backup})
                return
            elif self.path == "/api/upload":
                link = resolve("active", name)
                path = creation_path(name)
                if link.exists() or link.is_symlink() or path.exists():
                    raise ValueError(f"{name}: already exists")
                staged = []
                total = 0
                for f in req.get("files") or []:
                    rel = f.get("path", "")
                    parts = [p for p in rel.split("/") if p]
                    if not parts or rel.startswith("/") or ".." in parts:
                        raise ValueError(f"bad file path in upload: {rel}")
                    data = base64.b64decode(f.get("content_b64", ""))
                    total += len(data)
                    if total > 20 * 1024 * 1024:
                        raise ValueError("upload too large (>20 MB)")
                    staged.append((Path(*parts), data))
                if not staged:
                    raise ValueError("no files in upload")
                try:
                    for rel, data in staged:
                        dest = path / rel
                        dest.parent.mkdir(parents=True, exist_ok=True)
                        dest.write_bytes(data)
                except OSError:
                    shutil.rmtree(path, ignore_errors=True)
                    raise
                reconcile_links()
                self.send(200, {"ok": True, "files": len(staged),
                                "path": str(path.relative_to(REPO))})
                return
            elif self.path == "/api/new":
                link = resolve("active", name)
                path = creation_path(name)
                if link.exists() or link.is_symlink() or path.exists():
                    raise ValueError(f"{name}: already exists")
                path.mkdir(parents=True)
                (path / "SKILL.md").write_text(SKILL_TEMPLATE.format(name=name))
                reconcile_links()
                self.send(200, {"ok": True, "path": str(path.relative_to(REPO))})
                return
            else:
                self.send(404, {"error": "not found"})
                return
            self.send(200, {"ok": True})
        except (ValueError, OSError, json.JSONDecodeError) as e:
            self.send(400, {"error": str(e)})


def main():
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--port", type=int, default=7333)
    ap.add_argument("--no-open", action="store_true", help="don't open a browser")
    args = ap.parse_args()
    srv = ThreadingHTTPServer(("127.0.0.1", args.port), Handler)
    url = f"http://127.0.0.1:{args.port}"
    print(f"skills-ui: {url}  (repo: {REPO})")
    if not args.no_open:
        webbrowser.open(url)
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        print()
        sys.exit(0)


if __name__ == "__main__":
    main()
