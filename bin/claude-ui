<main>
  <h1><span class="cfg" id="cfgprefix">~/.claude/</span>config</h1>
  <p class="sub">Skills, commands, agents, and config files — versioned here, symlinked into the Claude config dir. Collections (like <b>work/</b>, gitignored) mirror the same shape and merge in automatically. Everything is plain files: review &amp; commit with git as usual.</p>
  <details id="links" open>
    <summary>links <span id="linksum"></span></summary>
    <div id="linkrows"></div>
    <div class="cfgdir">
      <span>config dir</span>
      <input type="text" id="cfgdir" placeholder="~/.claude">
      <button class="small" onclick="saveCfgDir()">set</button>
      <button class="small" onclick="resetCfgDir()">reset</button>
    </div>
    <div class="cfgdir hint" id="cfghint"></div>
  </details>
  <div class="tabs" id="tabs"></div>
  <div class="bar">
    <input type="search" id="q" placeholder="filter…" autofocus>
    <button onclick="newGroup()">+ folder</button>
    <button onclick="document.getElementById('up').click()">⇪ folder</button>
    <button onclick="document.getElementById('upf').click()">⇪ files</button>
    <button class="primary" onclick="newItem()">+ new</button>
    <input type="file" id="up" webkitdirectory multiple hidden>
    <input type="file" id="upf" multiple hidden>
  </div>
  <div id="groups" class="groups" hidden></div>
