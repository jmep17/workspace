  .badge.local { color: var(--orange); border-color: var(--orange); }
  .badge.group { color: var(--yellow); border-color: var(--yellow); }
  .badge.link { color: var(--blue); border-color: var(--blue); }
  .badge.warn { color: var(--red); border-color: var(--red); }
  .actions { display: flex; gap: .4rem; }
